{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/tyk-swe/pcr/main/schemas/packetcraftr.output.v1.schema.json",
  "$comment": "SPDX-License-Identifier: AGPL-3.0-only",
  "title": "PacketcraftR CLI output envelope v1",
  "description": "One typed aggregate JSON result or one independently valid NDJSON stream record.",
  "oneOf": [
    {
      "$ref": "#/$defs/aggregateSuccess"
    },
    {
      "$ref": "#/$defs/streamSuccess"
    },
    {
      "$ref": "#/$defs/aggregateError"
    },
    {
      "$ref": "#/$defs/streamError"
    }
  ],
  "$defs": {
    "baseEnvelope": {
      "type": "object",
      "required": [
        "schema",
        "command",
        "mode",
        "status",
        "diagnostics"
      ],
      "properties": {
        "schema": {
          "const": "packetcraftr.output/v1"
        },
        "command": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            null,
            "build",
            "dissect",
            "plan",
            "send",
            "exchange",
            "capture",
            "read",
            "replay",
            "scan",
            "traceroute",
            "dns",
            "fuzz",
            "interfaces",
            "routes"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "aggregate",
            "stream"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "sequence": {
          "$ref": "#/$defs/uint64"
        },
        "result": {
          "type": "object"
        },
        "error": {
          "$ref": "#/$defs/error"
        },
        "diagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnostic"
          }
        },
        "stats": {
          "$ref": "#/$defs/operationStats"
        }
      }
    },
    "aggregateSuccess": {
      "allOf": [
        {
          "$ref": "#/$defs/baseEnvelope"
        },
        {
          "type": "object",
          "required": [
            "result"
          ],
          "properties": {
            "command": {
              "type": "string"
            },
            "mode": {
              "const": "aggregate"
            },
            "status": {
              "const": "success"
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "sequence"
                ]
              },
              {
                "required": [
                  "error"
                ]
              }
            ]
          }
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/buildSuccess"
            },
            {
              "$ref": "#/$defs/dissectSuccess"
            },
            {
              "$ref": "#/$defs/planSuccess"
            },
            {
              "$ref": "#/$defs/sendSuccess"
            },
            {
              "$ref": "#/$defs/exchangeSuccess"
            },
            {
              "$ref": "#/$defs/replaySuccess"
            },
            {
              "$ref": "#/$defs/scanSuccess"
            },
            {
              "$ref": "#/$defs/tracerouteSuccess"
            },
            {
              "$ref": "#/$defs/dnsSuccess"
            },
            {
              "$ref": "#/$defs/fuzzSuccess"
            },
            {
              "$ref": "#/$defs/interfacesSuccess"
            },
            {
              "$ref": "#/$defs/routesSuccess"
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "streamSuccess": {
      "allOf": [
        {
          "$ref": "#/$defs/baseEnvelope"
        },
        {
          "type": "object",
          "required": [
            "sequence",
            "result"
          ],
          "properties": {
            "command": {
              "type": "string"
            },
            "mode": {
              "const": "stream"
            },
            "status": {
              "const": "success"
            }
          },
          "not": {
            "required": [
              "error"
            ]
          }
        },
        {
          "oneOf": [
            {
              "$ref": "#/$defs/readSuccess"
            },
            {
              "$ref": "#/$defs/captureSuccess"
            },
            {
              "$ref": "#/$defs/exchangeStreamSuccess"
            },
            {
              "$ref": "#/$defs/replayFrameSuccess"
            },
            {
              "$ref": "#/$defs/scanPortSuccess"
            },
            {
              "$ref": "#/$defs/tracerouteHopSuccess"
            },
            {
              "$ref": "#/$defs/dnsRecordSuccess"
            },
            {
              "$ref": "#/$defs/fuzzCaseSuccess"
            }
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "aggregateError": {
      "allOf": [
        {
          "$ref": "#/$defs/baseEnvelope"
        },
        {
          "type": "object",
          "required": [
            "error"
          ],
          "properties": {
            "mode": {
              "const": "aggregate"
            },
            "status": {
              "const": "error"
            }
          },
          "not": {
            "anyOf": [
              {
                "required": [
                  "sequence"
                ]
              },
              {
                "required": [
                  "result"
                ]
              }
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "streamError": {
      "allOf": [
        {
          "$ref": "#/$defs/baseEnvelope"
        },
        {
          "type": "object",
          "required": [
            "sequence",
            "error"
          ],
          "properties": {
            "mode": {
              "const": "stream"
            },
            "status": {
              "const": "error"
            }
          },
          "not": {
            "required": [
              "result"
            ]
          }
        }
      ],
      "unevaluatedProperties": false
    },
    "buildSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "build"
        },
        "result": {
          "$ref": "#/$defs/buildResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "dissectSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "dissect"
        },
        "result": {
          "$ref": "#/$defs/dissectResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "readSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "read"
        },
        "result": {
          "$ref": "#/$defs/frameResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "captureSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "capture"
        },
        "result": {
          "$ref": "#/$defs/captureStreamResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "interfacesSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "interfaces"
        },
        "result": {
          "$ref": "#/$defs/interfacesResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "planSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "plan"
        },
        "result": {
          "$ref": "#/$defs/planResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "routesSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "routes"
        },
        "result": {
          "$ref": "#/$defs/routesResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "sendSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "send"
        },
        "result": {
          "$ref": "#/$defs/sendResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "exchangeSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "exchange"
        },
        "result": {
          "$ref": "#/$defs/exchangeResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "replaySuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "replay"
        },
        "result": {
          "$ref": "#/$defs/replayResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "scanSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "scan"
        },
        "result": {
          "$ref": "#/$defs/scanResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "tracerouteSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "traceroute"
        },
        "result": {
          "$ref": "#/$defs/tracerouteResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "dnsSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "dns"
        },
        "result": {
          "$ref": "#/$defs/dnsResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "fuzzSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "fuzz"
        },
        "result": {
          "$ref": "#/$defs/fuzzResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "exchangeStreamSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "exchange"
        },
        "result": {
          "$ref": "#/$defs/exchangeStreamResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "replayFrameSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "replay"
        },
        "result": {
          "$ref": "#/$defs/replayStreamResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "scanPortSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "scan"
        },
        "result": {
          "$ref": "#/$defs/scanPortResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "tracerouteHopSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "traceroute"
        },
        "result": {
          "$ref": "#/$defs/tracerouteHopResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "dnsRecordSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "dns"
        },
        "result": {
          "$ref": "#/$defs/dnsRecordResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "fuzzCaseSuccess": {
      "type": "object",
      "properties": {
        "command": {
          "const": "fuzz"
        },
        "result": {
          "$ref": "#/$defs/fuzzCaseResult"
        }
      },
      "required": [
        "command",
        "result"
      ]
    },
    "buildResult": {
      "type": "object",
      "required": [
        "bytes_hex",
        "length",
        "packet",
        "layout",
        "requires_live_opt_in"
      ],
      "properties": {
        "bytes_hex": {
          "$ref": "#/$defs/hexBytes"
        },
        "length": {
          "$ref": "#/$defs/uint64"
        },
        "packet": {
          "$ref": "#/$defs/packetDocument"
        },
        "layout": {
          "$ref": "#/$defs/packetLayout"
        },
        "requires_live_opt_in": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "dissectResult": {
      "type": "object",
      "required": [
        "bytes_hex",
        "length",
        "link_type",
        "packet",
        "layout"
      ],
      "properties": {
        "bytes_hex": {
          "$ref": "#/$defs/hexBytes"
        },
        "length": {
          "$ref": "#/$defs/uint64"
        },
        "link_type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "packet": {
          "$ref": "#/$defs/packetDocument"
        },
        "layout": {
          "$ref": "#/$defs/packetLayout"
        }
      },
      "additionalProperties": false
    },
    "frameResult": {
      "type": "object",
      "required": [
        "frame"
      ],
      "properties": {
        "frame": {
          "$ref": "#/$defs/frame"
        }
      },
      "additionalProperties": false
    },
    "captureStreamResult": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "event",
            "frame"
          ],
          "properties": {
            "event": {
              "const": "frame"
            },
            "frame": {
              "$ref": "#/$defs/frame"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "frames"
          ],
          "properties": {
            "event": {
              "const": "complete"
            },
            "frames": {
              "$ref": "#/$defs/uint64"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "interfacesResult": {
      "type": "object",
      "required": [
        "interfaces"
      ],
      "properties": {
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/interface"
          }
        }
      },
      "additionalProperties": false
    },
    "planResult": {
      "type": "object",
      "required": [
        "route"
      ],
      "properties": {
        "route": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "routesResult": {
      "type": "object",
      "required": [
        "routes"
      ],
      "properties": {
        "routes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "sendResult": {
      "type": "object",
      "required": [
        "frame",
        "route"
      ],
      "properties": {
        "frame": {
          "$ref": "#/$defs/wireFrame"
        },
        "route": {
          "$ref": "#/$defs/materializedRoute"
        }
      },
      "additionalProperties": false
    },
    "exchangeResult": {
      "type": "object",
      "required": [
        "sent",
        "responses",
        "unanswered",
        "unsolicited",
        "undecoded"
      ],
      "properties": {
        "sent": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/wireFrame"
          }
        },
        "responses": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/exchangeResponse"
          }
        },
        "unanswered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/uint64"
          }
        },
        "unsolicited": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/decodedFrame"
          }
        },
        "undecoded": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/frame"
          }
        }
      },
      "additionalProperties": false
    },
    "replayResult": {
      "type": "object",
      "required": [
        "source_format",
        "timing",
        "requested_interface",
        "requested_link_mode",
        "frames_attempted",
        "frames_completed",
        "bytes_completed",
        "scheduled_duration",
        "frames"
      ],
      "properties": {
        "source_format": {
          "type": "string",
          "enum": [
            "pcap",
            "pcap_ng"
          ]
        },
        "timing": {
          "$ref": "#/$defs/replayTiming"
        },
        "requested_interface": {
          "$ref": "#/$defs/interfaceId"
        },
        "requested_link_mode": {
          "$ref": "#/$defs/linkMode"
        },
        "frames_attempted": {
          "$ref": "#/$defs/uint64"
        },
        "frames_completed": {
          "$ref": "#/$defs/uint64"
        },
        "bytes_completed": {
          "$ref": "#/$defs/uint64"
        },
        "scheduled_duration": {
          "$ref": "#/$defs/duration"
        },
        "frames": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/replayFrameResult"
          }
        }
      },
      "additionalProperties": false
    },
    "scanResult": {
      "type": "object",
      "required": [
        "target",
        "resolved_addresses",
        "ports"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "resolved_addresses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scanPort"
          }
        }
      },
      "additionalProperties": false
    },
    "tracerouteResult": {
      "type": "object",
      "required": [
        "target",
        "hops",
        "completion"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "hops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/traceHop"
          }
        },
        "completion": {
          "type": "string",
          "enum": [
            "destination_reached",
            "unreachable",
            "maximum_hops",
            "timeout",
            "error"
          ]
        }
      },
      "additionalProperties": false
    },
    "dnsResult": {
      "type": "object",
      "required": [
        "query_name",
        "query_type",
        "answers",
        "authorities",
        "additionals"
      ],
      "properties": {
        "query_name": {
          "type": "string"
        },
        "query_type": {
          "type": "string"
        },
        "answers": {
          "$ref": "#/$defs/dnsRecords"
        },
        "authorities": {
          "$ref": "#/$defs/dnsRecords"
        },
        "additionals": {
          "$ref": "#/$defs/dnsRecords"
        }
      },
      "additionalProperties": false
    },
    "fuzzResult": {
      "type": "object",
      "required": [
        "seed",
        "cases"
      ],
      "properties": {
        "seed": {
          "$ref": "#/$defs/uint64"
        },
        "cases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fuzzCase"
          }
        }
      },
      "additionalProperties": false
    },
    "exchangeStreamResult": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "event",
            "request_index",
            "frame"
          ],
          "properties": {
            "event": {
              "const": "sent"
            },
            "request_index": {
              "$ref": "#/$defs/uint64"
            },
            "frame": {
              "$ref": "#/$defs/wireFrame"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "request_index",
            "response",
            "latency"
          ],
          "properties": {
            "event": {
              "const": "response"
            },
            "request_index": {
              "$ref": "#/$defs/uint64"
            },
            "response": {
              "$ref": "#/$defs/decodedFrame"
            },
            "latency": {
              "$ref": "#/$defs/duration"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "request_index"
          ],
          "properties": {
            "event": {
              "const": "unanswered"
            },
            "request_index": {
              "$ref": "#/$defs/uint64"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "frame"
          ],
          "properties": {
            "event": {
              "const": "unsolicited"
            },
            "frame": {
              "$ref": "#/$defs/decodedFrame"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "frame"
          ],
          "properties": {
            "event": {
              "const": "undecoded"
            },
            "frame": {
              "$ref": "#/$defs/frame"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "event",
            "unanswered"
          ],
          "properties": {
            "event": {
              "const": "complete"
            },
            "unanswered": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/uint64"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "replayStreamResult": {
      "oneOf": [
        {
          "$ref": "#/$defs/replayFrameResult"
        },
        {
          "$ref": "#/$defs/replayResult"
        }
      ]
    },
    "replayFrameResult": {
      "type": "object",
      "required": [
        "source_sequence",
        "interface",
        "link_mode",
        "scheduled_delay",
        "bytes_sent",
        "frame",
        "transmitted"
      ],
      "properties": {
        "source_sequence": {
          "$ref": "#/$defs/uint64"
        },
        "interface": {
          "$ref": "#/$defs/interfaceId"
        },
        "link_mode": {
          "$ref": "#/$defs/linkMode"
        },
        "scheduled_delay": {
          "$ref": "#/$defs/duration"
        },
        "bytes_sent": {
          "$ref": "#/$defs/uint64"
        },
        "frame": {
          "$ref": "#/$defs/frame"
        },
        "transmitted": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "scanPortResult": {
      "type": "object",
      "required": [
        "target",
        "resolved_address",
        "port"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "resolved_address": {
          "type": "string"
        },
        "port": {
          "$ref": "#/$defs/scanPort"
        }
      },
      "additionalProperties": false
    },
    "tracerouteHopResult": {
      "type": "object",
      "required": [
        "target",
        "hop"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "hop": {
          "$ref": "#/$defs/traceHop"
        }
